        "id": 1000000
      },
      "writtenOn": "2026-05-11T07:44:14Z",
      "side": 1,
      "message": "Makes sense, but then we need to increase the metric of consumed messages as well, otherwise, you may have inconsistencies in the numbers.",
      "parentUuid": "9434dfa6_ab8b3066",
      "revId": "11cf83922b3185071fbc134e16a826f1808e4316",
      "serverId": "d5d70762-12d0-45a1-890d-524b12d3f735"
    },
